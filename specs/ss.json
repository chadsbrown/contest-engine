          {"id": "prec", "field_type": "Enum", "required": true, "domain": {"List": ["Q", "A", "B", "U", "M", "S"]}, "accept": [], "normalize_upper_trim": true},
          {"id": "ck", "field_type": "String", "required": true, "domain": null, "accept": [], "normalize_upper_trim": false},
