      {
        "when": null,
        "fields": [
          {"id": "prec", "value": {"Config": "my_prec"}, "normalize_upper_trim": true},
          {"id": "ck", "value": {"Config": "my_ck"}, "normalize_upper_trim": false},
          {"id": "sec", "value": {"Config": "my_sec"}, "normalize_upper_trim": true}
