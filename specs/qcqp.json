{
  "id": "qcqp",
  "name": "Quebec QSO Party",
  "cabrillo_contest": "QC-QSO-PARTY",
  "bands": ["B160", "B80", "B40", "B20", "B15", "B10"],
  "modes": ["CW", "SSB"],
  "dupe_dimension": "BandMode",
  "dupe_extra_rcvd_fields": ["loc"],
  "valid_qso": [
    [{"Or": [
      {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": true}}]},
      {"Eq": [{"Field": {"scope": "DEST", "key": "dxcc"}}, {"Value": {"Text": "VE"}}]}
    ]}, "non-VE2 stations may only work VE2 stations"]
  ],
  "exchange": {
    "received_variants": [
      {
        "when": null,
        "fields": [
          {"id": "rst", "field_type": "Rst", "required": true, "domain": null, "accept": [], "normalize_upper_trim": false},
          {"id": "loc", "field_type": "Enum", "required": true, "domain": null, "accept": [], "normalize_upper_trim": true, "multi_value_sep": "/"}
        ]
      }
    ],
    "sent_variants": [
      {
        "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": true}}]},
        "fields": [
          {"id": "rst", "value": {"Const": "599"}, "normalize_upper_trim": false},
          {"id": "loc", "value": {"Config": "my_region"}, "normalize_upper_trim": true}
        ]
      },
      {
        "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": false}}]},
        "fields": [
          {"id": "rst", "value": {"Const": "599"}, "normalize_upper_trim": false},
          {"id": "loc", "value": {"Config": "my_loc"}, "normalize_upper_trim": true}
        ]
      }
    ]
  },
  "multipliers": [
    {
      "id": "region_mult",
      "dimension": "Band",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": false}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "qc_regions"}}
        }
      ]
    },
    {
      "id": "in_region_state_mult",
      "dimension": "Band",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": true}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "us_states"}}
        }
      ]
    },
    {
      "id": "in_region_prov_mult",
      "dimension": "Band",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": true}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "ca_provinces"}}
        }
      ]
    }
  ],
  "points": [
    {"when": {"Eq": [{"Field": {"scope": "SESSION", "key": "mode"}}, {"Value": {"Text": "SSB"}}]}, "value": 1},
    {"when": null, "value": 2}
  ],
  "score": {"formula": "points_times_mults"},
  "config_fields": [
    {"id": "my_is_qc", "required": true, "required_when": null, "domain": null},
    {"id": "my_region", "required": false, "required_when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": true}}]}, "domain": {"External": {"name": "qc_regions"}}},
    {"id": "my_loc", "required": false, "required_when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_qc"}}, {"Value": {"Bool": false}}]}, "domain": null}
  ]
}
