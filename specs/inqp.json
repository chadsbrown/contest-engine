{
  "id": "inqp",
  "name": "Indiana QSO Party",
  "cabrillo_contest": "IN-QSO-PARTY",
  "bands": ["B160", "B80", "B40", "B20", "B15", "B10"],
  "modes": ["CW", "SSB"],
  "dupe_dimension": "BandMode",
  "dupe_extra_rcvd_fields": ["loc"],
  "valid_qso": [
    [{"Or": [
      {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": true}}]},
      {"Eq": [{"Field": {"scope": "DEST", "key": "is_wve"}}, {"Value": {"Bool": true}}]}
    ]}, "non-IN stations may only work IN stations"]
  ],
  "exchange": {
    "received_variants": [
      {
        "when": null,
        "fields": [
          {"id": "rst", "field_type": "Rst", "required": true, "domain": null, "accept": [], "normalize_upper_trim": false},
          {"id": "loc", "field_type": "Enum", "required": true, "domain": null, "accept": [], "normalize_upper_trim": true, "multi_value_sep": "/"}
        ]
      }
    ],
    "sent_variants": [
      {
        "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": true}}]},
        "fields": [
          {"id": "rst", "value": {"Const": "599"}, "normalize_upper_trim": false},
          {"id": "loc", "value": {"Config": "my_county"}, "normalize_upper_trim": true}
        ]
      },
      {
        "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": false}}]},
        "fields": [
          {"id": "rst", "value": {"Const": "599"}, "normalize_upper_trim": false},
          {"id": "loc", "value": {"Config": "my_loc"}, "normalize_upper_trim": true}
        ]
      }
    ]
  },
  "multipliers": [
    {
      "id": "county_mult",
      "dimension": "Mode",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": false}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "in_counties"}}
        }
      ]
    },
    {
      "id": "in_state_state_mult",
      "dimension": "Mode",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": true}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "us_states"}}
        }
      ]
    },
    {
      "id": "in_state_prov_mult",
      "dimension": "Mode",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": true}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "ca_provinces"}}
        }
      ]
    }
  ],
  "points": [
    {"when": null, "value": 2}
  ],
  "score": {"formula": "points_times_mults"},
  "config_fields": [
    {"id": "my_is_in", "required": true, "required_when": null, "domain": null},
    {"id": "my_county", "required": false, "required_when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": true}}]}, "domain": {"External": {"name": "in_counties"}}},
    {"id": "my_loc", "required": false, "required_when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_in"}}, {"Value": {"Bool": false}}]}, "domain": null}
  ]
}
