{
  "id": "moqp",
  "name": "Missouri QSO Party",
  "cabrillo_contest": "MO-QSO-PARTY",
  "bands": ["B160", "B80", "B40", "B20", "B15", "B10", "B6", "B2"],
  "modes": ["CW", "SSB", "DIGITAL"],
  "dupe_dimension": "BandMode",
  "dupe_extra_rcvd_fields": ["loc"],
  "valid_qso": [
    [{"Or": [
      {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": true}}]},
      {"Eq": [{"Field": {"scope": "DEST", "key": "is_wve"}}, {"Value": {"Bool": true}}]}
    ]}, "non-MO stations may only work MO stations"]
  ],
  "exchange": {
    "received_variants": [
      {
        "when": null,
        "fields": [
          {"id": "rst", "field_type": "Rst", "required": true, "domain": null, "accept": [], "normalize_upper_trim": false},
          {"id": "loc", "field_type": "Enum", "required": true, "domain": null, "accept": [], "normalize_upper_trim": true}
        ]
      }
    ],
    "sent_variants": [
      {
        "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": true}}]},
        "fields": [
          {"id": "rst", "value": {"Const": "599"}, "normalize_upper_trim": false},
          {"id": "loc", "value": {"Config": "my_county"}, "normalize_upper_trim": true}
        ]
      },
      {
        "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": false}}]},
        "fields": [
          {"id": "rst", "value": {"Const": "599"}, "normalize_upper_trim": false},
          {"id": "loc", "value": {"Config": "my_loc"}, "normalize_upper_trim": true}
        ]
      }
    ]
  },
  "multipliers": [
    {
      "id": "county_mult",
      "dimension": "Global",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": false}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "mo_counties"}}
        }
      ]
    },
    {
      "id": "in_state_state_mult",
      "dimension": "Global",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": true}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "us_states"}}
        }
      ]
    },
    {
      "id": "in_state_prov_mult",
      "dimension": "Global",
      "variants": [
        {
          "when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": true}}]},
          "key": {"scope": "RCVD", "key": "loc"},
          "domain": {"External": {"name": "ca_provinces"}}
        }
      ]
    }
  ],
  "points": [
    {"when": {"Eq": [{"Field": {"scope": "SESSION", "key": "mode"}}, {"Value": {"Text": "SSB"}}]}, "value": 1},
    {"when": null, "value": 2}
  ],
  "bonus_rules": [
    {
      "id": "w0ma_bonus",
      "when": {"DestCallIn": {"List": ["W0MA"]}},
      "amount": 100,
      "scope": "once"
    },
    {
      "id": "k0gq_bonus",
      "when": {"DestCallIn": {"List": ["K0GQ"]}},
      "amount": 100,
      "scope": "once"
    }
  ],
  "score": {"formula": "points_times_mults"},
  "config_fields": [
    {"id": "my_is_mo", "required": true, "required_when": null, "domain": null},
    {"id": "my_county", "required": false, "required_when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": true}}]}, "domain": {"External": {"name": "mo_counties"}}},
    {"id": "my_loc", "required": false, "required_when": {"Eq": [{"Field": {"scope": "CONFIG", "key": "my_is_mo"}}, {"Value": {"Bool": false}}]}, "domain": null}
  ]
}
